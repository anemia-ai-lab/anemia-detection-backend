# Supabase — SERVICE_ROLE solo en servidor de confianza; nunca en clientes.
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
APP_ENV=development
DEBUG=false

# Tests / CI: skip TF load in this process. Empty = off. `make test` sets DISABLE_TF=1 anyway.
DISABLE_TF=

# Optional historical threshold (POST /predict uses calibrated threshold). Do not set empty—omit line or use a number (e.g. RISK_THRESHOLD=0.5).

# Metrics: protects GET /metrics outside local-like APP_ENV when set
METRICS_BEARER_TOKEN=

# Rate limit (in-memory). TRUST_PROXY_HEADERS: only behind a trusted proxy that sets X-Forwarded-For safely
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_REQUESTS=20
RATE_LIMIT_PREDICT_REQUESTS=30
TRUST_PROXY_HEADERS=false

# CORS — comma-separated; empty in development uses a small local allowlist
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Storage
PREDICTIONS_STORAGE_BUCKET=prediction-images

# Model + calibration (defaults match thesis configuration)
MODEL_VERSION=v1.0
INFERENCE_MODEL_PATH=ml/artifacts/models/baseline_mobilenetv2.keras
INFERENCE_CALIBRATION_TEMPERATURE=0.7510018331928743
INFERENCE_CALIBRATION_OPERATIONAL_THRESHOLD=0.1680544387290045

# Image limits — empty values break parsing; omit keys to use Settings defaults
PREDICTION_IMAGE_MAX_BYTES=5242880
PREDICTION_IMAGE_MAX_EDGE_PX=1024
PREDICTION_IMAGE_MAX_PIXELS=12000000

# Nail-presence heuristic
NAIL_PRESENCE_MIN_SKIN_RATIO=0.012
