SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

APP_ENV=development
DEBUG=false

# CORS (origins separados por coma; vacío en development usa lista local segura para Swagger / demos)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Storage
PREDICTIONS_STORAGE_BUCKET=prediction-images

# Modelo (v1 final)
MODEL_VERSION=v1.0

# Ruta del modelo
INFERENCE_MODEL_PATH=ml/artifacts/models/baseline_mobilenetv2.keras

# Calibration (FINAL TESIS)
INFERENCE_CALIBRATION_TEMPERATURE=0.7510018331928743
INFERENCE_CALIBRATION_OPERATIONAL_THRESHOLD=0.1680544387290045

# Imagen
PREDICTION_IMAGE_MAX_BYTES=5242880
PREDICTION_IMAGE_MAX_EDGE_PX=1024

# Heurística uña
NAIL_PRESENCE_MIN_SKIN_RATIO=0.012